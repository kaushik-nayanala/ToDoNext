<UserControl x:Class="MainProject.View.BasicElementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MainProject.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400">
    <Canvas x:Name="MainCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid Height="{Binding ElementName=MainCanvas,Path=ActualHeight}" Width="{Binding ElementName=MainCanvas,Path=ActualWidth}">
            <StackPanel>
                <Button Content="Task"/>
                <Button Content="Line"/>
            </StackPanel>
        </Grid>
    </Canvas>
</UserControl>
