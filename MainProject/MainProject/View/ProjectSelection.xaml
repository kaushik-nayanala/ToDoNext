<Window x:Class="MainProject.View.ProjectSelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MainProject"
        mc:Ignorable="d" Background="Transparent" WindowStyle="None" AllowsTransparency="True" MouseDown="Window_MouseDown"
        Title="ProjectSelection" Height="450" Width="800">
    <Window.Resources>
        <local:VisualBrushScaleConverter x:Key="ScaleImageToElement"/>
        <ControlTemplate TargetType="Label" x:Key="BlurEffect">
            <Grid>

                <Border x:Name="BlurElement" CornerRadius="10"  Canvas.Left="{TemplateBinding Canvas.Left}" Canvas.Top="{TemplateBinding Canvas.Top}" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" BorderThickness="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border.Effect>
                        <BlurEffect Radius="10"/>
                    </Border.Effect>
                    <Border.Background>
                        <VisualBrush  Visual="{Binding ElementName=BackgroundImage}" Stretch="Fill">
                            <VisualBrush.RelativeTransform>
                                <MultiBinding Converter="{StaticResource ScaleImageToElement }">
                                    <Binding ElementName="BlurElement" Path="Width"/>
                                    <Binding ElementName="BlurElement" Path="Height"/>
                                    <Binding ElementName="BackgroundImage" Path="Width"/>
                                    <Binding ElementName="BackgroundImage" Path="Height"/>
                                    <Binding ElementName="BlurElement" Path="(Canvas.Left)"/>
                                    <Binding ElementName="BlurElement" Path="(Canvas.Top)"/>
                                </MultiBinding>
                            </VisualBrush.RelativeTransform>
                        </VisualBrush>
                    </Border.Background>
                </Border>
                <Border Opacity="0.5" BorderBrush="Transparent" CornerRadius="{Binding ElementName=BlurElement,Path=CornerRadius}" Canvas.Left="{Binding ElementName=BlurElement,Path = (Canvas.Left)}" Canvas.Top="{Binding ElementName=BlurElement,Path = (Canvas.Top)}" Height="{Binding ElementName=BlurElement,Path=ActualHeight}" Width="{Binding ElementName=BlurElement,Path=ActualWidth}" Background="{TemplateBinding Background}" BorderThickness="1" Margin="-1.5"/>
                <Border Opacity="1"    BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="{Binding ElementName=BlurElement,Path=CornerRadius}" Canvas.Left="{Binding ElementName=BlurElement,Path = (Canvas.Left)}" Canvas.Top="{Binding ElementName=BlurElement,Path = (Canvas.Top)}" Height="{Binding ElementName=BlurElement,Path=ActualHeight}" Width="{Binding ElementName=BlurElement,Path=ActualWidth}" Background="Transparent" BorderThickness="1" Margin="-1.5"/>

            </Grid>
        </ControlTemplate>
        <Style TargetType="Button">
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsPressed" Value="False"/>
                        <Condition Property="IsMouseOver" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Template" Value="{DynamicResource NotPressedTemplate}"/>
                    <Setter Property="Height" Value="50"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </MultiTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Template" Value="{DynamicResource PressedTemplate}"/>
                    <Setter Property="Height" Value="50"/>
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <ControlTemplate x:Key="PressedTemplate" TargetType="Button">
            <Grid>
                <Label BorderBrush="White" Background="Green" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"  Template="{StaticResource BlurEffect}" BorderThickness="{TemplateBinding BorderThickness}">
                    <Label.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Label.Triggers>
                </Label>
                <Label Content="{TemplateBinding Content}" Height="{TemplateBinding Height}" FontSize="22" Padding="0" Margin="50,2,0,2" VerticalAlignment="Center" VerticalContentAlignment="Center" FontWeight="SemiBold" Foreground="Black"/>
            </Grid> 
        </ControlTemplate>
        <ControlTemplate x:Key="NotPressedTemplate" TargetType="Button">
            <Grid MaxHeight="{Binding Height,ElementName=TextBoxTag}">
                <Label  Background="Black" Opacity="1" Template="{StaticResource BlurEffect}" BorderBrush="Black" Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" BorderThickness="{TemplateBinding BorderThickness}">
                    <Label.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Label.Triggers>
                </Label>
                <Label Content="{TemplateBinding Content}" Height="{TemplateBinding Height}" FontSize="22" Padding="0" Margin="50,2,0,2" VerticalAlignment="Center" VerticalContentAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="Movement" TargetType="Path">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" From="0" To="100" RepeatBehavior="Forever" Duration="0:0:1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Canvas x:Name="MainCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
        <Border CornerRadius="4" BorderThickness="1" BorderBrush="Black" Height="{Binding ElementName=MainCanvas,Path=ActualHeight}" Width="{Binding ElementName=MainCanvas,Path=ActualWidth}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#d9d9d9"/>
        <Image x:Name="BackgroundImage" Source="/Image/Image1.jpg" Stretch="UniformToFill" Height="{Binding ElementName=MainCanvas,Path=ActualHeight}" Width="{Binding ElementName=MainCanvas,Path=ActualWidth}"/>
        <Label  Template="{StaticResource BlurEffect}" BorderBrush="Black" Background="DimGray" Height="430" Width="200"  Canvas.Left="10" Canvas.Top="10">
            <Label.Effect>
                <DropShadowEffect Color="Black" Direction="0" BlurRadius="5" ShadowDepth="2"/>
            </Label.Effect>
        </Label>
        <Button Content="New" Canvas.Left="10" Canvas.Top="10" Width="180" Click="NewProject"/>
        <Button Content="Open" Canvas.Left="10" Canvas.Top="70" Width="180" Click="OpenedProject"/>
        <Button Content="Recent" Canvas.Left="10" Canvas.Top="130" Width="180" Click="RecentProject"/>
        <Button Content="Exit" Canvas.Left="10" Canvas.Top="190" Width="180" Click="ExitApp"/>

        <Label Height="190" Width="570" Canvas.Top="10" Canvas.Left="220" BorderBrush="Black" Background="DimGray" Template="{StaticResource BlurEffect}">
            <Label.Effect>
                <DropShadowEffect Color="Black" Direction="0" BlurRadius="5" ShadowDepth="2"/>
            </Label.Effect>
        </Label>
        <Label Content="ToDoNext is a software build to keep
            &#10;track on what to do next in the project.
            &#10;
            &#10;The project could be:-
            &#10;* Building a software with new tech stack.
            &#10;* Editing a large scale video.
            &#10;* Travel itenerary."
            Height="140" Width="430" Canvas.Top="20" Canvas.Left="230" FontFamily="Consolas" Foreground="White" FontWeight="Bold" FontSize="15">
            <Label.Effect>
                <DropShadowEffect Color="Black" BlurRadius="0" ShadowDepth="1"/>
            </Label.Effect>
        </Label>
        <Label Content="As long as a project is build step by step." FontFamily="Consolas" Foreground="LightGray" FontSize="10"
            Canvas.Top="160" Canvas.Left="230">
            <Label.Effect>
                <DropShadowEffect BlurRadius="0" ShadowDepth="1"/>
            </Label.Effect>
        </Label>

        <Label Height="230" Width="570" Canvas.Top="210" Canvas.Left="220" BorderBrush="Black" Background="DimGray" Template="{StaticResource BlurEffect}">
            <Label.Effect>
                <DropShadowEffect Color="Black" Direction="0" BlurRadius="5" ShadowDepth="2"/>
            </Label.Effect>
        </Label>
        <Label Canvas.Top="220" Canvas.Left="230" Foreground="White" Content="Saved Projects" FontFamily="Consolas">
            <Label.Effect>
                <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="0"/>
            </Label.Effect>
        </Label>
        <Label Height="190" Width="550" Canvas.Top="240" Canvas.Left="230" Background="Black" Template="{StaticResource BlurEffect}"/>
    </Canvas>

</Window>
